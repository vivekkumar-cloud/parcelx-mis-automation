# ParcelX Basic Auth (HTTP layer)
PARCELX_BASIC_USER=your_basic_auth_username
PARCELX_BASIC_PASS=your_basic_auth_password

# ParcelX Form Login
PARCELX_FORM_USER=your_form_username
PARCELX_FORM_PASS=your_form_password

# Google Apps Script Web App URL
# Deploy apps-script/Code.gs as a Web App → paste the /exec URL here
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
